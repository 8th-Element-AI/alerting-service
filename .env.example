# -----------------------------------------------------------------------
# DATABASE (required)
# -----------------------------------------------------------------------
# PostgreSQL connection string
# Local:  postgresql://user:password@localhost:5432/dbname
# Docker: postgresql://errormon:errormon@postgres:5432/errormon
DATABASE_URL=postgresql://user:password@localhost:5432/errormon

# Redis connection string
# Local:  redis://localhost:6379
# Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------
# CLIENT LIBRARY (errormon) — only needed in the service using the library
# -----------------------------------------------------------------------
# URL of the API server (no trailing slash)
ALERTING_API_URL=http://localhost:5001

# Optional API key — must match ALERTING_API_KEY on the API server
# Remove or leave blank to disable auth
ALERTING_API_KEY=your-secret-api-key

# Name of the service using the library (appears in alerts)
SERVICE_NAME=my-service

# Environment tag (e.g. production, staging, development)
ENVIRONMENT=production

# -----------------------------------------------------------------------
# API SERVER (app.py)
# -----------------------------------------------------------------------
# Port the Flask API listens on
PORT=5001

# API key to authenticate incoming requests from the library
# Must match ALERTING_API_KEY set in the client
ALERTING_API_KEY=your-secret-api-key

# -----------------------------------------------------------------------
# GCP PUB/SUB (optional — if not set, errors are processed directly)
# -----------------------------------------------------------------------
# Your GCP project ID
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Path to your GCP service account JSON key file
# Docker: /secrets/your-service-account.json
# Local:  /path/to/your-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/secrets/your-service-account.json

# Full Pub/Sub topic path
# Format: projects/<project-id>/topics/<topic-name>
GCP_TOPIC_ID=projects/your-gcp-project-id/topics/your-topic-name

# -----------------------------------------------------------------------
# SUBSCRIBER (subscriber.py)
# -----------------------------------------------------------------------
# Full Pub/Sub subscription path
# Format: projects/<project-id>/subscriptions/<subscription-name>
ALERTING_SUBSCRIPTION=projects/your-gcp-project-id/subscriptions/your-subscription-name

# How long (seconds) to suppress duplicate alerts for the same error
# Default: 360 (6 minutes)
DEDUP_WINDOW_SECONDS=360

# -----------------------------------------------------------------------
# EMAIL ALERTS (required for notifications)
# -----------------------------------------------------------------------
# Comma-separated list of recipients
ALERT_EMAIL_GROUP=oncall@yourcompany.com,team@yourcompany.com

# Sender email address
ALERT_FROM_EMAIL=alerts@yourcompany.com

# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com

# For Gmail: use an App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password

# Use TLS (recommended)
SMTP_USE_TLS=true

# -----------------------------------------------------------------------
# SHARED
# -----------------------------------------------------------------------
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
